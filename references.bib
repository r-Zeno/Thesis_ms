}

@article{elyamanyTranscranialAlternatingCurrent2021,
  title = {Transcranial Alternating Current Stimulation ({{tACS}}): From Basic Mechanisms towards First Applications in Psychiatry},
  shorttitle = {Transcranial Alternating Current Stimulation ({{tACS}})},
  author = {Elyamany, Osama and Leicht, Gregor and Herrmann, Christoph S. and Mulert, Christoph},
  date = {2021-02},
  journaltitle = {European Archives of Psychiatry and Clinical Neuroscience},
