@article{allenMetacognitiveAbilityCorrelates2017,
  title = {Metacognitive Ability Correlates with Hippocampal and Prefrontal Microstructure},
  author = {Allen, Micah and Glen, James C. and Müllensiefen, Daniel and Schwarzkopf, Dietrich Samuel and Fardo, Francesca and Frank, Darya and Callaghan, Martina F. and Rees, Geraint},
