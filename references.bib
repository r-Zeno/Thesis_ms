@article{decoCholinergicControlCortical2011,
  title = {Cholinergic Control of Cortical Network Interactions Enables Feedback-Mediated Attentional Modulation: {{Cholinergic}} Control of Cortical Network Interactions},
  shorttitle = {Cholinergic Control of Cortical Network Interactions Enables Feedback-Mediated Attentional Modulation},
  author = {Deco, Gustavo and Thiele, Alexander},
