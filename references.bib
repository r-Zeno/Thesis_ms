}

@article{stephaneEvaluationSpeechMisattribution2010,
  title = {Evaluation of Speech Misattribution Bias in Schizophrenia},
  author = {Stephane, M. and Kuskowski, M. and McClannahan, K. and Surerus, C. and Nelson, K.},
  date = {2010-05},
  journaltitle = {Psychological Medicine},
