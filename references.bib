@article{jachsIndependenceVisualAwareness2015,
  title = {On the Independence of Visual Awareness and Metacognition: {{A}} Signal Detection Theoretic Analysis.},
  shorttitle = {On the Independence of Visual Awareness and Metacognition},
  author = {Jachs, Barbara and Blanco, Manuel J. and Grantham-Hill, Sarah and Soto, David},
  date = {2015-04},
  journaltitle = {Journal of Experimental Psychology: Human Perception and Performance},
  shortjournal = {Journal of Experimental Psychology: Human Perception and Performance},
