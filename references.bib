  author = {Saygin, Z.M. and Kliemann, D. and Iglesias, J.E. and Van Der Kouwe, A.J.W. and Boyd, E. and Reuter, M. and Stevens, A. and Van Leemput, K. and McKee, A. and Frosch, M.P. and Fischl, B. and Augustinack, J.C.},
  date = {2017-07},
  journaltitle = {NeuroImage},
