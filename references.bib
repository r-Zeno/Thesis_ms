@article{mcdonnellInformationCapacityStochastic2009,
  title = {Information Capacity of Stochastic Pooling Networks Is Achieved by Discrete Inputs},
  author = {McDonnell, Mark D.},
  date = {2009-04-06},
  journaltitle = {Physical Review E},
  shortjournal = {Phys. Rev. E},
  volume = {79},
  number = {4},
