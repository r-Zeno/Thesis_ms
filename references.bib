}

@article{rosenthalLearningRecognitionNonconscious2016,
  title = {Learning and {{Recognition}} of a {{Non-conscious Sequence}} of {{Events}} in {{Human Primary Visual Cortex}}},
  author = {Rosenthal, Clive~R. and Andrews, Samantha~K. and Antoniades, Chrystalina~A. and Kennard, Christopher and Soto, David},
