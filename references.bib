@article{martinezModelStimulusSpecificNeural2008,
  title = {A {{Model}} of {{Stimulus-Specific Neural Assemblies}} in the {{Insect Antennal Lobe}}},
  author = {Martinez, Dominique and Montejo, Noelia},
  editor = {Friston, Karl J.},
  date = {2008-08-01},
  journaltitle = {PLoS Computational Biology},
  shortjournal = {PLoS Comput Biol},
