}

@article{miallModulationLinguisticPrediction2016,
  title = {Modulation of Linguistic Prediction by {{TDCS}} of the Right Lateral Cerebellum},
  author = {Miall, R.C. and Antony, J. and Goldsmith-Sumner, A. and Harding, S.R. and McGovern, C. and Winter, J.L.},
