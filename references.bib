@article{ellisMachineLearningUsing2023,
  title = {Machine Learning Using Magnetic Stochastic Synapses},
  author = {Ellis, Matthew O A and Welbourne, Alexander and Kyle, Stephan J and Fry, Paul W and Allwood, Dan A and Hayward, Thomas J and Vasilaki, Eleni},
  date = {2023-06},
  journaltitle = {Neuromorphic Computing and Engineering},
