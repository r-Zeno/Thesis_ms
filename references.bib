}

@article{korotkovHeteroclinicCyclesSwitching2025,
  title = {Heteroclinic Cycles and Switching Activity in Model of Neuronal Ensemble},
  author = {Korotkov, Alexander G. and Syundyukova, Ekaterina V. and Gubina, Elena V. and Osipov, Grigory V.},
