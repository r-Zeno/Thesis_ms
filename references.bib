@inproceedings{linares-barrancoAdaptiveRoboticArm2024,
  title = {Adaptive {{Robotic Arm Control}} with a {{Spiking Recurrent Neural Network}} on a {{Digital Accelerator}}},
  booktitle = {2024 31st {{IEEE International Conference}} on {{Electronics}}, {{Circuits}} and {{Systems}} ({{ICECS}})},
