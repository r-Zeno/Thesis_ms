@article{samahaDissociatingPerceptualConfidence2016,
  title = {Dissociating {{Perceptual Confidence}} from {{Discrimination Accuracy Reveals No Influence}} of {{Metacognitive Awareness}} on {{Working Memory}}},
  author = {Samaha, Jason and Barrett, John J. and Sheldon, Andrew D. and LaRocque, Joshua J. and Postle, Bradley R.},
