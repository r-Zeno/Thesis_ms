@article{batesBehavioralNeuralCorrelates2024,
  title = {Behavioral and {{Neural Correlates}} of {{Visual Working Memory Reveal Metacognitive Aspects}} of {{Mental Imagery}}},
  author = {Bates, Kathryn E. and Smith, Marie L. and Farran, Emily K. and Machizawa, Maro G.},
  date = {2024-02-01},
