@article{stenningNeuromorphicOverparameterisationFewshot2024,
  title = {Neuromorphic Overparameterisation and Few-Shot Learning in Multilayer Physical Neural Networks},
  author = {Stenning, Kilian D. and Gartside, Jack C. and Manneschi, Luca and Cheung, Christopher T. S. and Chen, Tony and Vanstone, Alex and Love, Jake and Holder, Holly and Caravelli, Francesco and Kurebayashi, Hidekazu and Everschor-Sitte, Karin and Vasilaki, Eleni and Branford, Will R.},
