@article{menckePredictionUncertaintyDissociating2021,
  title = {Prediction under Uncertainty: {{Dissociating}} Sensory from Cognitive Expectations in Highly Uncertain Musical Contexts},
  shorttitle = {Prediction under Uncertainty},
  author = {Mencke, Iris and Quiroga-Martinez, David Ricardo and Omigie, Diana and Michalareas, Georgios and Schwarzacher, Franz and Haumann, Niels Trusbak and Vuust, Peter and Brattico, Elvira},
  date = {2021-12},
  journaltitle = {Brain Research},
