}

@article{bagherzadehAlphaSynchronyNeurofeedback2020,
  title = {Alpha {{Synchrony}} and the {{Neurofeedback Control}} of {{Spatial Attention}}},
  author = {Bagherzadeh, Yasaman and Baldauf, Daniel and Pantazis, Dimitrios and Desimone, Robert},
  date = {2020-02},
  journaltitle = {Neuron},
  shortjournal = {Neuron},
