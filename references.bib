@article{brysonStateTransitionsInhibitory2021,
  title = {State Transitions through Inhibitory Interneurons in a Cortical Network Model},
  author = {Bryson, Alexander and Berkovic, Samuel F. and Petrou, Steven and Grayden, David B.},
