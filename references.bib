@article{skerritt-davisComputationalFrameworkInvestigating2021,
  title = {Computational Framework for Investigating Predictive Processing in Auditory Perception},
  author = {Skerritt-Davis, Benjamin and Elhilali, Mounya},
  date = {2021-08},
  journaltitle = {Journal of Neuroscience Methods},
  shortjournal = {Journal of Neuroscience Methods},
  volume = {360},
