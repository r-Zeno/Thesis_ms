}

@article{bulsaraStochasticResonanceSingle1991,
  title = {Stochastic Resonance in a Single Neuron Model: {{Theory}} and Analog Simulation},
  shorttitle = {Stochastic Resonance in a Single Neuron Model},
  author = {Bulsara, Adi and Jacobs, E. W. and Zhou, Ting and Moss, Frank and Kiss, Laszlo},
