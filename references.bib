@article{gershmanGenerativeAdversarialBrain2019,
  title = {The {{Generative Adversarial Brain}}},
  author = {Gershman, Samuel J.},
  date = {2019-09-18},
  journaltitle = {Frontiers in Artificial Intelligence},
  shortjournal = {Front. Artif. Intell.},
  volume = {2},
