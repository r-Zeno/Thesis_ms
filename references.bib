@article{schenkNonspikingInterneuronsDrosophila2023,
  title = {Nonspiking {{Interneurons}} in the {{{\mkbibemph{Drosophila}}}} {{Antennal Lobe Exhibit Spatially Restricted Activity}}},
  author = {Schenk, Jonathan E. and Gaudry, Quentin},
  date = {2023-01},
